{
  "info": {
    "name": "Library Management System",
    "description": "Complete API collection for the Library Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "memberToken", "value": "" },
    { "key": "librarianToken", "value": "" },
    { "key": "bookId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Member",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"member\"\n}"
            }
          }
        },
        {
          "name": "Register Librarian",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Librarian\",\n  \"email\": \"librarian@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"librarian\"\n}"
            }
          }
        },
        {
          "name": "Login Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('memberToken', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login Librarian",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('librarianToken', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"librarian@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Add Book (Librarian)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('bookId', res.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{librarianToken}}" }
            ],
            "url": "{{baseUrl}}/books",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Clean Code\",\n  \"author\": \"Robert C. Martin\",\n  \"isbn\": \"978-0132350884\",\n  \"category\": \"Programming\",\n  \"quantity\": 5\n}"
            }
          }
        },
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": "{{baseUrl}}/books"
          }
        },
        {
          "name": "Get Book By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": "{{baseUrl}}/books/{{bookId}}"
          }
        },
        {
          "name": "Update Book (Librarian)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{librarianToken}}" }
            ],
            "url": "{{baseUrl}}/books/{{bookId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 10,\n  \"category\": \"Software Engineering\"\n}"
            }
          }
        },
        {
          "name": "Delete Book (Librarian)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": "{{baseUrl}}/books/{{bookId}}"
          }
        }
      ]
    },
    {
      "name": "Borrow & Return",
      "item": [
        {
          "name": "Borrow Book (Member)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": "{{baseUrl}}/books/{{bookId}}/borrow"
          }
        },
        {
          "name": "Return Book (Member)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": "{{baseUrl}}/books/{{bookId}}/return"
          }
        },
        {
          "name": "My Borrowed Books (Member)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{memberToken}}" }],
            "url": "{{baseUrl}}/members/me/books"
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "Get All Members (Librarian)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": "{{baseUrl}}/members"
          }
        },
        {
          "name": "Delete Member (Librarian)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{librarianToken}}" }],
            "url": "{{baseUrl}}/members/:memberId"
          }
        }
      ]
    }
  ]
}
